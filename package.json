{
  "name": "sculptor-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,Portfolio,Admin -c cyan,yellow,magenta \"node server.js\" \"vite\" \"vite --config vite.admin.config.js\"",
    "dev:portfolio": "vite",
    "dev:admin": "vite --config vite.admin.config.js",
    "dev:api": "node server.js",
    "build": "vite build",
    "build:admin": "vite build --config vite.admin.config.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
