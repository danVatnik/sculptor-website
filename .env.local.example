# Copy this to .env.local and fill in your values.
# DO NOT commit .env.local to git.

# Required: Vercel Blob read/write token
# Get this from: vercel.com → your project → Storage → Blob → Manage → Tokens
first_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Optional: Protect the /api endpoints with a secret password
# This same value is what you enter in the /admin login screen.
# If not set, the API is open (fine for local dev behind localhost).
ADMIN_TOKEN=your-secret-admin-password

# Required for contact form: Resend API key
# Get this from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxx
